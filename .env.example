# =====================================================================
# phonebio / FieldBio voice agent — environment template
# Copy to .env (gitignored) and fill in.
# =====================================================================

# --- Server ---
PORT=8080
# Public URL Vapi POSTs tool calls to (set after exposing via tunnel/deploy).
# The checked-in assistant uses the hosted InsForge webhook, so these are only
# needed when replacing it with a local tunnel or alternate deployment.
PUBLIC_BASE_URL=https://your-tunnel-or-deploy.example.com
VAPI_WEBHOOK_URL=https://your-tunnel-or-deploy.example.com/webhook
# Only needed if vapi/assistant.field-biology-worker.json uses custom-llm.
VAPI_CUSTOM_LLM_URL=https://your-tunnel-or-deploy.example.com/custom-llm
# Shared secret Vapi sends in the x-vapi-secret header (set the same in Vapi).
VAPI_WEBHOOK_SECRET=change-me-long-random-string

# --- Vapi (telephony + voice orchestration) ---
# Dashboard -> API Keys -> Private key. Used to create/assign assistant config.
# VAPI_PRIVATE_KEY is preferred if both variables are set.
VAPI_PRIVATE_KEY=
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
# Your test number, for reference / outbound test calls.
VAPI_TEST_NUMBER=
# Set only after make vapi-verify-call succeeds for the intended assistant/phone.
PHONEBIO_CALL_VERIFIED=

# --- LLM routing ---
# local is the default. Add nebius only after hackathon/free credits are active:
# LLM_PROVIDER_ORDER=nebius,local
LLM_PROVIDER_ORDER=local

# Local Ollama — truly offline. qwen3:1.7b does reliable function-calling;
# qwen2.5:1.5b does not (it answers but never emits tool_calls).
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:1.7b

# Optional Nebius Token Factory provider, following the cookbook .env pattern.
# No OpenAI key is used. Leave unset unless free credits/API access are approved.
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# --- InsForge (optional content/data backend; v1 runs file-local without it) ---
INSFORGE_API_KEY=
INSFORGE_BASE_URL=
