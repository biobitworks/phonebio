# =====================================================================
# phonebio / FieldBio voice agent — environment template
# Copy to .env (gitignored) and fill in.
# =====================================================================

# --- Server ---
PORT=8080
# Public URL Vapi POSTs tool calls to (set after exposing via tunnel/deploy).
PUBLIC_BASE_URL=https://your-tunnel-or-deploy.example.com
VAPI_WEBHOOK_URL=https://your-tunnel-or-deploy.example.com/webhook
VAPI_CUSTOM_LLM_URL=https://your-tunnel-or-deploy.example.com/custom-llm
# Shared secret Vapi sends in the x-vapi-secret header (set the same in Vapi).
VAPI_WEBHOOK_SECRET=change-me-long-random-string

# --- Vapi (telephony + voice orchestration) ---
# Dashboard -> API Keys -> Private key. Used to PUSH assistant/tool/phone config.
VAPI_PRIVATE_KEY=
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
# Your test number, for reference / outbound test calls.
VAPI_TEST_NUMBER=

# --- LLM routing (offline-only): local Ollama is the only default provider ---
LLM_PROVIDER_ORDER=local

# Local Ollama — truly offline. qwen3:1.7b does reliable function-calling;
# qwen2.5:1.5b does not (it answers but never emits tool_calls).
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:1.7b

# --- InsForge (optional content/data backend; v1 runs file-local without it) ---
INSFORGE_API_KEY=
INSFORGE_BASE_URL=
