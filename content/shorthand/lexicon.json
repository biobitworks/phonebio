  "_meta": {
    "purpose": "Gregg-shorthand-inspired compression for spoken field notes. Goal: turn a verbose voice note into a compact, structured, low-bandwidth field-log line that survives intermittent connectivity and is fast to read back over the phone.",
    "principles": [
      "Phonetic/essential reduction: keep the sounds that carry meaning, drop filler.",
      "Brief forms: frequent field-bio terms map to fixed short codes.",
      "Vowel omission: unknown long words drop interior vowels (keep first letter).",
      "Phrasing: common multi-word phrases blend into one token.",
      "Prefix/suffix abbreviation: standard affixes get fixed marks."
    ],
